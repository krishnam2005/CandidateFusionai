# CandidateFusion AI — Environment Variables
# Copy this file to .env and populate the values.
# Never commit .env to version control.

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=CandidateFusion AI
APP_ENV=development        # development | staging | production
LOG_LEVEL=INFO             # DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_FORMAT=json            # json | console

# ─── GitHub API ──────────────────────────────────────────────────────────────
# Personal Access Token (PAT) — required for higher rate limits (5000 req/hr vs 60)
GITHUB_TOKEN=ghp_your_token_here
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_API_TIMEOUT_SECONDS=15
GITHUB_API_MAX_RETRIES=3

# ─── Pipeline Configuration ──────────────────────────────────────────────────
PIPELINE_DEFAULT_CONFIG_PATH=config/default.json
PIPELINE_OUTPUT_DIR=outputs
PIPELINE_LOG_DIR=logs
PIPELINE_MAX_WORKERS=4

# ─── FastAPI ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
API_RELOAD=true            # Set false in production

# ─── PDF Processing ──────────────────────────────────────────────────────────
PDF_MAX_PAGES=50
PDF_TEXT_EXTRACTION_STRATEGY=pdfplumber   # pdfplumber | pymupdf

# ─── Validation ──────────────────────────────────────────────────────────────
VALIDATION_STRICT_MODE=false
